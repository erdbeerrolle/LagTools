0ce4880bd41c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fieldAndIdxFact", "[", "expr_", "]"}], ":=", 
   RowBox[{"Times", "@@", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"List", "@@", "expr"}], ",", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", 
            RowBox[{"_", "?", "fieldQ"}]}], "]"}], "&&", 
          RowBox[{"indexFreeQ", "[", "#", "]"}]}], ")"}]}], "&"}]}], 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"SumGroupByValues", "[", "expr_", "]"}], ":=", 
   RowBox[{"Total", "/@", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"GroupBy", "[", 
       RowBox[{
        RowBox[{"SumToList", "[", "expr", "]"}], ",", "fieldAndIdxFact"}], 
       "]"}], "//", "Values"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"HoldFieldPrefacts", "[", "e_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "a", "}"}], ",", 
     RowBox[{"Total", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Factor", "@", 
         RowBox[{"SumGroupByValues", "@", 
          RowBox[{"Expand", "@", "e"}]}]}], ")"}], "/.", 
       RowBox[{"{", 
        RowBox[{"a_Plus", "->", 
         RowBox[{"Hold", "[", "a", "]"}]}], "}"}]}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"renTermHold", "[", "e_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ren", ",", "a"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ren", "=", 
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{"e", "/.", 
           RowBox[{"Join", "[", 
            RowBox[{"renormFields", ",", "renormParams"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"alpha", ",", "0", ",", "1"}], "}"}]}], "]"}], "//", 
        "Normal"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"HoldFieldPrefacts", "@", "ren"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"renormalize", "[", "e_", "]"}], ":=", 
   RowBox[{"HoldFieldPrefacts", "[", 
    RowBox[{"renTermHold", "/@", "e"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9918897720347853`*^9, 3.9918897864522676`*^9}, {
  3.991890438081489*^9, 3.991890438579359*^9}, {3.991894042541607*^9, 
  3.9918940704124947`*^9}, {3.991894194587566*^9, 3.991894202601008*^9}, {
  3.991900490824657*^9, 3.991900492680169*^9}, {3.991900576199204*^9, 
  3.9919005870794687`*^9}},
 CellLabel->
  "In[181]:=",ExpressionUUID->"b13ea70e-ffa0-4a43-991a-59b3277628e9"],

