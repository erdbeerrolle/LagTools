Cell["Feynman rules", "Subsection",
 CellChangeTimes->{{3.9917496347922573`*^9, 
  3.9917496362072163`*^9}},ExpressionUUID->"d51d4a69-4fc7-43fb-8caa-\
559146c31ad6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"report", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"legs", "=", 
       RowBox[{"key", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momenta", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "legs"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momCons", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "@", "momenta"}], ")"}], "[", "a_", "]"}], "->", 
         RowBox[{"-", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", "a", "]"}], "&"}], "/@", 
             RowBox[{"Rest", "@", "momenta"}]}], ")"}]}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ref", "=", 
       RowBox[{
        RowBox[{"feynruleMap", "[", "legs", "]"}], "/.", " ", 
        "tadpoleCtZero"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"comp", "=", 
       RowBox[{"feynmanRule", "[", 
        RowBox[{"Lren", ",", "legs"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"diffNorm", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ref", "-", "comp"}], ")"}], "/.", 
        RowBox[{"Join", "[", 
         RowBox[{"normalizationRpl", ",", "momCons"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"diffSimpl", "=", "diffNorm"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"diffSimpl", "===", "0"}], ",", 
        RowBox[{"OutputAgreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"OutputDisagreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}]}],
        "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"key", ",", 
       RowBox[{"DownValues", "[", "feynruleMap", "]"}]}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Column", "[", 
   RowBox[{"report", ",", 
    RowBox[{"Dividers", "->", "Center"}]}], "]"}], "  "}]}], "Input",
