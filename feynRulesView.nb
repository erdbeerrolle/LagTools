Cell[CellGroupData[{

Cell["Output formatting", "Subsection",
 CellChangeTimes->{{3.9917493959255*^9, 
  3.991749400465025*^9}},ExpressionUUID->"b2baa44f-163d-4e7d-a232-\
8df3a923a937"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"OutputAgreement", "[", 
    RowBox[{"legs_", ",", "ref_", ",", "comp_", ",", "diff_"}], "]"}], ":=", 
   RowBox[{"Print", "[", 
    RowBox[{"Style", "[", 
     RowBox[{
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<AGREEMENT: \>\"", ",", "legs"}], "}"}], "]"}], ",", 
      "Bold", ",", "Green"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"OutputDisagreement", "[", 
    RowBox[{"legs_", ",", "ref_", ",", "comp_", ",", "diff_"}], "]"}], ":=", 
   RowBox[{"Print", "[", 
    RowBox[{"Column", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<MISMATCH: \>\"", ",", "legs"}], "}"}], "]"}], ",", 
         "Bold", ",", "Red"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<  reference : \>\"", ",", "ref"}], "}"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<  computed  : \>\"", ",", "comp"}], "}"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<  difference: \>\"", ",", "diff"}], "}"}], "]"}]}], 
      "}"}], "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.991911710261201*^9, 3.991911733762855*^9}, {
   3.9919126631838627`*^9, 3.9919126826383963`*^9}, 3.991912848588361*^9, {
   3.991913004359672*^9, 3.991913018211063*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"710009dd-63bc-4b27-ae0c-4f2dd04c1d81"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Compare Feynman rule for given ext. legs", "Subsection",
 CellChangeTimes->{{3.9919120278984833`*^9, 
  3.991912037322279*^9}},ExpressionUUID->"dd64fa3b-9ea4-4982-8501-\
bc4bf0ba27f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"momentumCons", "[", "legs_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "momenta"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"momenta", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "legs"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "@", "momenta"}], ")"}], "[", "a_", "]"}], ":>", 
         RowBox[{"-", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", "a", "]"}], "&"}], "/@", 
             RowBox[{"Rest", "@", "momenta"}]}], ")"}]}]}]}], ",", 
        RowBox[{
         RowBox[{"Sq", "[", 
          RowBox[{"First", "@", "momenta"}], "]"}], "->", 
         RowBox[{"Sq", "[", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{"Rest", "@", "momenta"}], ")"}]}], "]"}]}]}], "}"}]}]}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9919123106293583`*^9, 3.991912381715745*^9}, {
  3.991916919227455*^9, 3.991916996441646*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"b5eee667-5a26-4bff-a276-5169de48f828"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"CompareRule", "[", 
    RowBox[{"L_", ",", "legs_", ",", 
     RowBox[{"map_", ":", "feynruleMap"}], ",", 
     RowBox[{"canIdc_", ":", 
      RowBox[{"{", 
       RowBox[{"LI", ",", "FI", ",", "GI"}], "}"}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"comp", ",", "ref", ",", "diff"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"comp", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"feynmanRule", "[", 
          RowBox[{"L", ",", "legs"}], "]"}], "//", "ReleaseHold"}], "//", 
        "ReleaseHold"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"ref", "=", 
       RowBox[{
        RowBox[{"map", "[", "legs", "]"}], "/.", 
        RowBox[{"Join", "[", 
         RowBox[{"expandSC", ",", "tadpoleCtZero"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"diff", "=", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"ref", "-", "comp"}], "//.", 
             RowBox[{"Join", "[", 
              RowBox[{"normalizationRpl", ",", 
               RowBox[{"momentumCons", "[", "legs", "]"}]}], "]"}]}], ")"}], "//", 
           RowBox[{
            RowBox[{"canonical", "[", 
             RowBox[{"#", ",", "canIdc"}], "]"}], "&"}]}], ")"}], "//", 
         "ExplMassMat"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"diff", " ", "===", " ", "0"}], ",", 
        RowBox[{"OutputAgreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diff"}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"OutputDisagreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diff"}], "]"}]}], 
       "]"}], ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BatchComp", "[", 
    RowBox[{"L_", ",", "legs_", ",", 
     RowBox[{"map_", ":", "feynruleMap"}], ",", 
     RowBox[{"canIdc_", ":", 
      RowBox[{"{", 
       RowBox[{"LI", ",", "FI", ",", "GI"}], "}"}]}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"CompareRule", "[", 
      RowBox[{"L", ",", "#", ",", "map", ",", "canIdc"}], "]"}], "&"}], "/@", 
    "legs"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.991912156458302*^9, 3.991912223191471*^9}, {
   3.991912450580798*^9, 3.9919124644036627`*^9}, {3.9919127292950068`*^9, 
   3.9919127464609327`*^9}, {3.9919127969707747`*^9, 3.991912809417493*^9}, {
   3.991912870265473*^9, 3.991912877064171*^9}, {3.991912912619029*^9, 
   3.9919129169072857`*^9}, 3.991913102741637*^9, {3.991913621479807*^9, 
   3.991913621894693*^9}, 3.9919138267904053`*^9, {3.9919141667348013`*^9, 
   3.991914170589429*^9}, {3.9919143023479967`*^9, 3.991914310056451*^9}, {
   3.991914378073841*^9, 3.991914392408588*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"cde14295-e30e-4d6f-8938-717269cc42e0"]
}, Open  ]]
}, Open  ]],

