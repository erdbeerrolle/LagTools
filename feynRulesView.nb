     "setting", " ", "renomralization", " ", "constants", " ", "to", " ", 
     "zero"}]}], " ", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ctZero", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"dsw", "->", "0"}], ",", 
       RowBox[{"dcw", "->", "0"}], ",", 
