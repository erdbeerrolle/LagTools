       RowBox[{"Print", "[", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{"myruleFact", "-", "ruleFact"}], "]"}], "]"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ShowDifference", "[", 
     RowBox[{"rule_", ",", " ", "myrule_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "myrule0", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"myrule0", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"myrule", "/.", 
           RowBox[{"alpha", "->", "0"}]}], ")"}], "//", "FullSimplify"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"myrule0", "===", "0"}], ",", 
         RowBox[{"PrintDiff", "[", 
          RowBox[{"myrule", ",", "rule"}], "]"}], ",", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"myruleFact", ",", "ruleFact"}], "}"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"myruleFact", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"FullSimplify", "[", 
                  RowBox[{"myrule", "/", "myrule0"}], "]"}], "/.", 
                 RowBox[{"alpha", "->", "1"}]}], ")"}], "//", "Expand"}]}], ";",
              "\[IndentingNewLine]", 
             RowBox[{"ruleFact", "=", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"rule", "/", "myrule0"}], ")"}], "//", 
                "FullSimplify"}], "//", "Expand"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"PrintDiff", "[", 
              RowBox[{"myruleFact", ",", "ruleFact"}], "]"}], ";"}]}], "]"}], 
          ";"}]}], "\[IndentingNewLine]", "]"}], ";"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
