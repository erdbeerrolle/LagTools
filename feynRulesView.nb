       RowBox[{"key", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momenta", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "legs"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momCons", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "@", "momenta"}], ")"}], "[", "a_", "]"}], "->", 
         RowBox[{"-", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", "a", "]"}], "&"}], "/@", 
             RowBox[{"Rest", "@", "momenta"}]}], ")"}]}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ref", "=", 
       RowBox[{
        RowBox[{"feynruleMap", "[", "legs", "]"}], "/.", " ", "ctZero"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"comp", "=", 
       RowBox[{"feynmanRule", "[", 
        RowBox[{"Ltotal", ",", "legs"}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"diffNorm", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ref", "-", "comp"}], ")"}], "/.", 
        RowBox[{"Join", "[", 
         RowBox[{"normalizationRpl", ",", "momCons"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"diffSimpl", "=", 
       RowBox[{
        RowBox[{"FullSimplify", "[", "diffNorm", "]"}], "//", "canonical"}]}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{"diffSimpl", "===", "0"}], "]"}], "||", 
         RowBox[{"TrueQ", "[", 
          RowBox[{"Simplify", "[", 
           RowBox[{"diffSimpl", "==", "0"}], "]"}], "]"}]}], ",", 
        RowBox[{"OutputAgreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"OutputDisagreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}]}],
        "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"key", ",", 
       RowBox[{"DownValues", "[", "feynruleMap", "]"}]}], "}"}]}], 
