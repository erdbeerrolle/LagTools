        RowBox[{"dZeL", "[", "__", "]"}], "->", "0"}], ",", 
       RowBox[{
        RowBox[{"dZeR", "[", "__", "]"}], "->", "0"}], ",", 
       RowBox[{
        RowBox[{"dZuL", "[", "__", "]"}], "->", "0"}], ",", 
       RowBox[{
        RowBox[{"dZuR", "[", "__", "]"}], "->", "0"}], ",", 
       RowBox[{
        RowBox[{"dZdL", "[", "__", "]"}], "->", "0"}], ",", 
       RowBox[{
        RowBox[{"dZdR", "[", "__", "]"}], "->", "0"}], ",", 
       RowBox[{
        RowBox[{"dZnuL", "[", "__", "]"}], "->", "0"}], ",", " ", 
       RowBox[{
        RowBox[{"dMdiagd", "[", "__", "]"}], "->", "0"}], ",", 
       RowBox[{
