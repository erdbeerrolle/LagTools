Cell[CellGroupData[{

Cell["Tree Feynman rules, 3-point and 4-point vertices", "Section",
 CellChangeTimes->{{3.991749282359025*^9, 
  3.99174929991076*^9}},ExpressionUUID->"5d8c7d75-5ef8-4ce6-b178-\
49cf5bfa43c2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"report", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"legs", "=", 
       RowBox[{"key", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momenta", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "legs"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momCons", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "@", "momenta"}], ")"}], "[", "a_", "]"}], "->", 
         RowBox[{"-", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", "a", "]"}], "&"}], "/@", 
             RowBox[{"Rest", "@", "momenta"}]}], ")"}]}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ref", "=", 
       RowBox[{
        RowBox[{"feynruleMap", "[", "legs", "]"}], "/.", " ", "ctZero"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"comp", "=", 
       RowBox[{"feynmanRule", "[", 
        RowBox[{"Ltotal", ",", "legs"}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"diffNorm", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ref", "-", "comp"}], ")"}], "/.", 
        RowBox[{"Join", "[", 
         RowBox[{"normalizationRpl", ",", "momCons"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"diffSimpl", "=", 
       RowBox[{
        RowBox[{"FullSimplify", "[", "diffNorm", "]"}], "//", "canonical"}]}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{"diffSimpl", "===", "0"}], "]"}], "||", 
         RowBox[{"TrueQ", "[", 
          RowBox[{"Simplify", "[", 
           RowBox[{"diffSimpl", "==", "0"}], "]"}], "]"}]}], ",", 
        RowBox[{"OutputAgreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"OutputDisagreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}]}],
        "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"key", ",", 
       RowBox[{"DownValues", "[", "feynruleMap", "]"}]}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Column", "[", 
   RowBox[{"report", ",", 
    RowBox[{"Dividers", "->", "Center"}]}], "]"}], "  "}]}], "Input",
 CellChangeTimes->{{3.991749316601843*^9, 3.991749318392806*^9}, {
  3.9917974772967*^9, 3.991797479245942*^9}},
