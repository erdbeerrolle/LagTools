Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"OutputAgreement", "[", 
    RowBox[{"legs_", ",", "ref_", ",", "comp_", ",", "diff_"}], "]"}], ":=", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<AGREEMENT: \>\"", ",", "legs"}], "}"}], "]"}], ",", 
        "Bold", ",", "Green"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<  reference : \>\"", ",", "ref"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<  computed  : \>\"", ",", "comp"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<  difference: \>\"", ",", "diff"}], "}"}], "]"}], ",", 
      RowBox[{"Spacer", "[", "0", "]"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"OutputDisagreement", "[", 
    RowBox[{"legs_", ",", "ref_", ",", "comp_", ",", "diff_"}], "]"}], ":=", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<MISMATCH: \>\"", ",", "legs"}], "}"}], "]"}], ",", 
        "Bold", ",", "Red"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<  reference : \>\"", ",", "ref"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<  computed  : \>\"", ",", "comp"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<  difference: \>\"", ",", "diff"}], "}"}], "]"}], ",", 
      RowBox[{"Spacer", "[", "0", "]"}]}], "}"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"710009dd-63bc-4b27-ae0c-4f2dd04c1d81"]
