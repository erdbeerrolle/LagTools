Cell[CellGroupData[{

Cell["Tree Feynman rules, propagators [Full agreement]", "Section",
 CellChangeTimes->{{3.991749282359025*^9, 3.99174929991076*^9}, {
  3.991749518062441*^9, 3.991749519395013*^9}, {3.991807647691248*^9, 
  3.991807654475058*^9}},ExpressionUUID->"55cc62ef-cc72-4dfc-a558-\
d14dde00eec0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"report", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"legs", "=", 
       RowBox[{"key", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momenta", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "legs"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momCons", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "@", "momenta"}], ")"}], "[", "a_", "]"}], "->", 
         RowBox[{"-", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", "a", "]"}], "&"}], "/@", 
             RowBox[{"Rest", "@", "momenta"}]}], ")"}]}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ref", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"propagatorMap", "[", "legs", "]"}], "/.", " ", "ctZero"}], 
         ")"}], "//", "ExplMassMat"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"comp", "=", 
       RowBox[{"feynmanRule", "[", 
        RowBox[{"Ltotal", ",", "legs"}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"diffNorm", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ref", "-", "comp"}], ")"}], "/.", 
        RowBox[{"Join", "[", 
         RowBox[{"normalizationRpl", ",", "momCons"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"diffSimpl", "=", 
       RowBox[{
        RowBox[{"FullSimplify", "[", "diffNorm", "]"}], " ", "//", " ", 
        RowBox[{
         RowBox[{"canonical", "[", 
          RowBox[{"#", ",", 
           RowBox[{"{", "LI", "}"}]}], "]"}], "&"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"diffSimpl", "===", "0"}], ",", 
        RowBox[{"OutputAgreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"OutputDisagreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}]}],
        "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"key", ",", 
       RowBox[{"DownValues", "[", "propagatorMap", "]"}]}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Column", "[", 
   RowBox[{"report", ",", 
    RowBox[{"Dividers", "->", "Center"}]}], "]"}], "  "}]}], "Input",
 CellChangeTimes->{{3.991734409348526*^9, 3.991734449505611*^9}, 
   3.991749031681225*^9, {3.991749374529148*^9, 3.991749376491807*^9}, {
   3.99175691826433*^9, 3.991756918685443*^9}, {3.991798814853263*^9, 
