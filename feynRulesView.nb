Cell[BoxData[
 RowBox[{
  RowBox[{"report", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"legs", "=", 
       RowBox[{"key", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momenta", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "legs"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momCons", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "@", "momenta"}], ")"}], "[", "a_", "]"}], "->", 
         RowBox[{"-", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", "a", "]"}], "&"}], "/@", 
             RowBox[{"Rest", "@", "momenta"}]}], ")"}]}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ref", "=", 
       RowBox[{
        RowBox[{"feynruleMap", "[", "legs", "]"}], "/.", " ", "ctZero"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"comp", "=", 
       RowBox[{"feynmanRule", "[", 
        RowBox[{"Lren", ",", "legs"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"diffNorm", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ref", "-", "comp"}], ")"}], "/.", 
        RowBox[{"Join", "[", 
         RowBox[{"normalizationRpl", ",", "momCons"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"diffSimpl", "=", 
       RowBox[{
