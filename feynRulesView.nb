Cell[BoxData[
 RowBox[{
  RowBox[{"normalizationRpl", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"MZ", "->", 
      RowBox[{"MW", "/", "cw"}]}], ",", " ", 
     RowBox[{"PR", "->", 
      RowBox[{"1", "-", "PL"}]}], ",", 
     RowBox[{
      RowBox[{"ElectricCharge", "[", "el", "]"}], "->", 
      RowBox[{"-", "1"}]}], ",", 
     RowBox[{
      RowBox[{"ElectricCharge", "[", "nu", "]"}], "->", "0"}], ",", 
     RowBox[{
      RowBox[{"ElectricCharge", "[", "uq", "]"}], "->", 
      RowBox[{"2", "/", "3"}]}], ",", 
     RowBox[{
      RowBox[{"ElectricCharge", "[", "dq", "]"}], "->", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "3"}]}], ",", " ", 
     RowBox[{"eps", "->", "0"}]}], "}"}]}], ";"}]], "Input",
