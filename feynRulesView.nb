Cell[BoxData[
 RowBox[{
  RowBox[{"report", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"legs", "=", 
       RowBox[{"key", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momenta", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "legs"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"momCons", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"First", "@", "momenta"}], ")"}], "[", "a_", "]"}], "->", 
         RowBox[{"-", 
          RowBox[{"Total", "@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", "a", "]"}], "&"}], "/@", 
             RowBox[{"Rest", "@", "momenta"}]}], ")"}]}]}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ref", "=", 
       RowBox[{
        RowBox[{"feynruleMap", "[", "legs", "]"}], "/.", " ", "ctZero"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"comp", "=", 
       RowBox[{"feynmanRule", "[", 
        RowBox[{"Lren", ",", "legs"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"diffNorm", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ref", "-", "comp"}], ")"}], "/.", 
        RowBox[{"Join", "[", 
         RowBox[{"normalizationRpl", ",", "momCons"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"diffSimpl", "=", 
       RowBox[{
        RowBox[{"FullSimplify", "[", "diffNorm", "]"}], "//", "canonical"}]}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"TrueQ", "[", 
          RowBox[{"diffSimpl", "===", "0"}], "]"}], "||", 
         RowBox[{"TrueQ", "[", 
          RowBox[{"Simplify", "[", 
           RowBox[{"diffSimpl", "==", "0"}], "]"}], "]"}]}], ",", 
        RowBox[{"OutputAgreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"OutputDisagreement", "[", 
         RowBox[{"legs", ",", "ref", ",", "comp", ",", "diffSimpl"}], "]"}]}],
        "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"key", ",", 
       RowBox[{"DownValues", "[", "feynruleMap", "]"}]}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.991749316601843*^9, 3.991749318392806*^9}, {
  3.9917496605776854`*^9, 
  3.991749661026614*^9}},ExpressionUUID->"50f85272-6667-4e67-9f24-\
2d200af6be33"],

